{
  "manifest_version": 3,
  "name": "치즈 플래터 - Chzzk Platter",
  "short_name": "ChzzkPlatter",
  "version": "1.6.0",
  "description": "치지직 검색·오디오 믹서·비디오 필터·실시간 따라잡기·레이아웃 정리를 한 접시에",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "unlimitedStorage",
    "webRequest"
  ],
  "host_permissions": [
    "https://chzzk.naver.com/*",
    "https://m.naver.com/shorts/*",
    "https://studio.chzzk.naver.com/*",
    "https://api.chzzk.naver.com/*",
    "https://creatorhub-api.naver.com/*",
    "https://apis.naver.com/*",
    "https://*.navercdn.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chzzk.naver.com/*",
        "https://studio.chzzk.naver.com/*"
      ],
      "js": ["src/hls.min.js", "src/searchQuery.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chzzk.naver.com/*"],
      "js": ["src/audioMixer.js", "src/videoFilter.js"],
      "css": ["src/audioMixer.css", "src/videoFilter.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://chzzk.naver.com/*", "https://m.naver.com/shorts/*"],
      "js": ["src/clipButtonHide.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "치즈 플래터",
    "default_popup": "settings.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "src/popup.css",
        "src/themeInit.js",
        "src/searchQuery.js",
        "src/popup.js",
        "no-search-results-found-animation.svg",
        "searching-animation.svg",
        "loading.svg"
      ],
      "matches": [
        "https://chzzk.naver.com/*",
        "https://studio.chzzk.naver.com/*"
      ]
    }
  ]
}
